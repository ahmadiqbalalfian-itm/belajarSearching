int main() {
	int awal=0, akhir=7, tengah, cari, angka [8]={8,7,6,5,4,3,2};
	cout<<"masukkan angka yang ingin dicari\t:";
	cin>>cari;
	while(awal<=akhir){
		tengah = (awal+akhir)/2;
		if (cari<angka[tengah]){
			awal=tengah+1;
