//mengurutkan nomor handphone dengan bubble short dan mencari dengan binary search secara ascending, 
#include <iostream>
using namespace std;
int main(){
	
	//jangan lupa penyesuaian praktikum kemain dengan modul dikit-dikit (entahlah butuh apa ngga)
	
	//deklarasikan array no hp dan variabel yang diperlukan
	int f, //iterasi
	awal=0, //indeks awal
	akhir=12, //indeks akhir
	posisi,//posisi indeks elemen (untuk short), dan nilai tengah (untuk binary search)
	wadah,//seperti temp, untuk menyimpan sementara nilai yang dipindahkan, juga menyimpan input nilai yang dicari (binary search)
	nomor[12]={0,8,5,6,0,6,8,2,3,3,2,7};//no hp
	
	//karena akan pakai binary search, maka harus dishort(urutkan) dulu
	
	for (f=12;f>=0;f--){//looping dimensi pertama berjalan untuk mengecek seluruh elemen
		for (posisi=12;posisi>=0;posisi--){//kalau dimensi kedua akan menggeser elemen paling banyak sesuai jumlah elemen, bisa jadi data nilai 0 berada di akhir sementara depannya lebih besar semua
			if(nomor[posisi-1]>nomor[posisi]){
				wadah = nomor[posisi-1];//memindahkan(duplikat) nilai array indeks kedua dari akhir (11), ke wadah
				nomor[posisi-1]=nomor[posisi]; //mengganti nilai array indeks 11 dengan nilai array indeks terakhir (12)
				nomor[posisi]=wadah;//array indeks belakang kemudian diganti dengan nilai indeks sebelumnya yang lebih besar, dan diambil dari wadah	
			}
		}
	}
	//menampilkan data yang telah diurutkan
	cout<<"Data yang telah diurutkan Ascending\n\n";
	for(f=0;f<=12;f++){
		cout<<nomor[f]<<" ";
	}
	
	//karena data sudah urut, lanjut kita mencari nilai dengan binary search
	cout<<"\n\nMasukkan nomor yang ingin anda cari\t:";
	cin>>wadah;//variabel wadah sudah tidak dipakai, bisa untuk menyipan nomor inputan user
	
	while(awal<=akhir){
		posisi=(awal+akhir)/2;
		if (wadah>nomor[posisi]){//jika nomor yang dicari lebih besar dari nilai di tengah, maka pencarian lanjut ke kanan karena Ascending ()
			awal=posisi+1;//pencarian dilanjut pada bagian kanan
		} else if(wadah<nomor[posisi]){//jika nomor yang dicari lebih kecil dari nilai di tengah
			akhir=posisi-1;//pencarian dilanjut pada bagian kiri
		} /*else if (wadah==nomor[posisi]){
			cout<<"nomor "<<wadah<<" ditemukan pada indeks "<<posisi;
		}*/ else {//jika nomor yang dicari tidak ditemukan
			awal=akhir+1;//maka dihentikan (ngga bisa pakai break? harusnya sih ngga karena ini while dan syaratnya udah jelas)
			//ternyata ini tetap akan dijalankan, karena kondisinya memungkinkan pencarian sampai akhir, meskipun sudah ditemukan posisi yang sesuai
		}
	}
	//harusnya ini bisa ngga sih masuk while jadi else if ke 3?
	if (wadah==nomor[posisi]){//jika looping di atas berhasil menemukan posisi nomor yang dicari
		cout<<"\n\nNomor "<<wadah<<" ditemukan pada indeks "<<posisi<<"\n\n";//posisinya ditampilkan, kenapa ditaruh luar while? agar
	} else {
		cout<<"\n\nNomor "<<wadah<<" tidak ditemukan\n\n";//kita masukkan sini aja, karena situasi dan kondisinya sama
	}
}
